# Base de datos (Railway provee esta URL automáticamente)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/enpinch_db"

# JWT - Genera un string aleatorio seguro (mínimo 32 caracteres)
JWT_SECRET="cambia_esto_por_un_string_muy_largo_y_seguro_123456"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV="development"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5500"
